class Solution {
    public int findNumbers(int[] nums) {
        int count=0;
        for(int num:nums){
            int d=0;
            int t=num;

            while(t > 0){
                d++;
                t=t/10;
            }

            if(d%2==0){
                count++;
            }

        }
        return count;
    }
}
