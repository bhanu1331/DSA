
 
public class Main { 
    public static void main(String[] args) {
        int n=7;
        boolean prime =true;
        
        for(int i=2;i<Math.sqrt(n);i++){
            if((n%i)==0){
                prime=false;
                break;
            }
        }
        System.out.println(prime?"prime":"not prime");
        
}
}
