class Solution {
    public int[] divisors(int n) {
        ArrayList<Integer> arr = new ArrayList<>();

        for(int i = 1; i <= n; i++) {
            if(n % i == 0) {
                arr.add(i);
            }
        }

        int res[] = new int[arr.size()];

        for(int i = 0; i < arr.size(); i++) {
            res[i] = arr.get(i);
        }

        return res;
    }
}
