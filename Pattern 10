class Solution {
    public void pattern10(int n) {

        // Increasing part
        for(int i = 1; i <= n; i++) {
            for(int j = 0; j < i; j++) {
                System.out.print("*");
            }
            System.out.println();
        }

        // Decreasing part
        for(int i = n - 1; i >= 1; i--) {
            for(int j = 0; j < i; j++) {
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
