
 
public class Main { 
    public static void main(String[] args) {
        int largest=Integer.MIN_VALUE;
        int second=Integer.MAX_VALUE;
        
        int []arr={12,45,23,66,78};
        for(int num:arr){
            if(num>largest){
                second=largest;
                largest=num;
            }else if(num > second && num!=largest){
                second=num;
            }
        }
        System.out.println(second);
        
        
}
}
