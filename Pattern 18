class Solution {
    public void pattern18(int n) {
        for(int i=0;i<n;i++){
            for(int j=i;j>=0;j--){
                System.out.print((char)('A'+(n-j-1)));
                if(j>0){
                    System.out.print(" ");
                }
                
            }
            System.out.println("");
        }

    }
}
